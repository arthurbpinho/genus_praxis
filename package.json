{
  "name": "genus-praxis",
  "version": "1.0.0",
  "description": "Genus Práxis — Plataforma de Simulação Clínica (white label All_OS, estética laranja)",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npx vite --host",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npx vite build",
    "start": "node server/index.js",
    "postinstall": "cd client && npm install"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "concurrently": "8.2.2",
    "cors": "2.8.6",
    "dotenv": "17.4.1",
    "express": "4.22.2",
    "express-rate-limit": "7.5.1",
    "jsonwebtoken": "9.0.3",
    "openai": "6.38.0"
  }
}
